<configuration scan="true">
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <statusListener class="ch.qos.logback.core.status.NopStatusListener"/>

    <!-- ─────────────────────────────────────────────────────────────────────
         Custom converter: masks passwords / tokens in log messages.
         Use %maskedMsg instead of %msg wherever sensitive data may appear.
         ───────────────────────────────────────────────────────────────────── -->
    <conversionRule conversionWord="maskedMsg"
                    class="ai.chat.backend.logging_common.converter.SensitiveMaskingConverter"/>

    <!-- ── Spring Boot / OTel properties ──────────────────────────────────── -->
    <springProperty name="SERVICE_NAME" scope="context"
                    source="spring.application.name" defaultValue="unknown-service"/>

    <!-- ─────────────────────────────────────────────────────────────────────
         DEV  – human-readable coloured output.
         Includes traceId / spanId from MDC (populated by OTel / Micrometer Tracing).
         ───────────────────────────────────────────────────────────────────── -->
    <appender name="CONSOLE_TEXT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(%-5level) %clr([%thread]){faint} %clr(%logger{36}){cyan} %clr([%mdc{traceId:--} %mdc{spanId:--}]){magenta} %clr([req=%mdc{requestId:-} user=%mdc{userId:-}]){yellow} - %maskedMsg%n</pattern>
        </encoder>
    </appender>

    <!-- ─────────────────────────────────────────────────────────────────────
         TEST / PROD  – structured JSON output (Logstash-compatible).
         Every field becomes a top-level JSON key, which Loki / ELK can index.
         ───────────────────────────────────────────────────────────────────── -->
    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- Rename the default "message" field and apply masking -->
            <messageFieldName>message</messageFieldName>
            <!-- Embed MDC keys as first-class JSON fields -->
            <includeMdcKeyName>requestId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
            <!-- Static fields added to every log record -->
            <customFields>{"service":"${SERVICE_NAME}"}</customFields>
            <fieldNames>
                <timestamp>@timestamp</timestamp>
                <version>@version</version>
                <levelValue>[ignore]</levelValue>
            </fieldNames>
        </encoder>
    </appender>

    <!-- ─────────────────────────────────────────────────────────────────────
         ASYNC wrapper around JSON appender for PROD:
         – Non-blocking  (queue capacity = 512 events)
         – Drops TRACE+DEBUG under backpressure (neverBlock = false keeps WARN/ERROR)
         ───────────────────────────────────────────────────────────────────── -->
    <appender name="ASYNC_JSON" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>20</discardingThreshold>  <!-- discard DEBUG/TRACE when queue >80% full -->
        <includeCallerData>false</includeCallerData>
        <neverBlock>false</neverBlock>
        <appender-ref ref="CONSOLE_JSON"/>
    </appender>

    <!-- ── Silence noisy libraries ──────────────────────────────────────── -->
    <logger name="org.hibernate.SQL"                         level="WARN"/>
    <logger name="org.hibernate.type.descriptor.sql"         level="WARN"/>
    <logger name="org.springframework.web.servlet.mvc.method" level="WARN"/>
    <logger name="org.springframework.security"               level="WARN"/>

    <!-- ── Profile-specific root loggers ─────────────────────────────────── -->
    <springProfile name="dev">
        <logger name="ai.chat" level="DEBUG"/>
        <root level="INFO">
            <appender-ref ref="CONSOLE_TEXT"/>
        </root>
    </springProfile>

    <springProfile name="test">
        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
        </root>
    </springProfile>

    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="ASYNC_JSON"/>
        </root>
    </springProfile>


    <root level="INFO">
        <appender-ref ref="CONSOLE_TEXT"/>
    </root>

</configuration>